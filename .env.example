# ═══════════════════════════════════════════════════════════════════
#  feetiPlay — Backend — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────
PORT=8001
NODE_ENV=development                 # development | production

# ── Base de données ──────────────────────────────────────────────────
# IMPORTANT : feetiPlay partage la même DB que feeti2 (mono-DB)
# Pointer vers la même instance PostgreSQL que feeti2
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/feeti2
# En production : utiliser le même DATABASE_URL que feeti2

# ── JWT ─────────────────────────────────────────────────────────────
# Secrets propres à feetiPlay (pour les comptes admin feetiPlay)
ACCESS_TOKEN_SECRET=CHANGE_ME_FEETIPLAY_ACCESS_SECRET
REFRESH_TOKEN_SECRET=CHANGE_ME_FEETIPLAY_REFRESH_SECRET
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# ── SSO feeti2 ───────────────────────────────────────────────────────
# IMPORTANT : doit être identique à ACCESS_TOKEN_SECRET de feeti2
# Permet à feetiPlay d'accepter les JWT feeti2 (SSO cross-app)
FEETI2_JWT_SECRET=SAME_AS_FEETI2_ACCESS_TOKEN_SECRET

# ── Intégration feeti2 ────────────────────────────────────────────────
FEETI2_API_URL=http://localhost:8000/api
FEETI2_FRONT_URL=http://localhost:3000
FEETI_SYNC_SECRET=CHANGE_ME_SYNC_SECRET  # identique à feeti2

# ── URLs (CORS) ──────────────────────────────────────────────────────
FRONT_URL=http://localhost:5173      # URL du frontend feetiPlay

# ── Sécurité ────────────────────────────────────────────────────────
BCRYPT_SALT=10

# ── Email SMTP ───────────────────────────────────────────────────────
# Même config que feeti2 (peuvent partager le même compte SMTP)
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_app_password_gmail
EMAIL_FROM="FeetiPlay <noreply@feetiplay.app>"

# ── Cloudinary (upload d'images) ─────────────────────────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Mux (streaming vidéo live) ───────────────────────────────────────
# Obtenir sur dashboard.mux.com > Settings > API Access Tokens
# Permissions requises : Mux Video (Full Access)
MUX_TOKEN_ID=CHANGE_ME_MUX_TOKEN_ID
MUX_TOKEN_SECRET=CHANGE_ME_MUX_TOKEN_SECRET
