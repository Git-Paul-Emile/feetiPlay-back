# Base de données PostgreSQL — créer la DB: createdb feetiplay
DATABASE_URL="postgresql://postgres:password@localhost:5432/feetiplay"

# JWT
ACCESS_TOKEN_SECRET="feetiplay_access_secret_change_me"
REFRESH_TOKEN_SECRET="feetiplay_refresh_secret_change_me"
ACCESS_TOKEN_EXPIRY="1d"
REFRESH_TOKEN_EXPIRY="7d"

# Serveur
PORT=8001
NODE_ENV=development

# Frontend (CORS)
FRONT_URL="http://localhost:5173"

# Bcrypt
BCRYPT_SALT=10
