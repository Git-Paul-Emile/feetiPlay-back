generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  viewer
  premium
  streamer
  admin
  super_admin
}

enum SubscriptionPlan {
  free
  basic
  premium
  vip
}

enum AdminRole {
  super_admin
  admin
  moderator
  finance
  marketing
}

enum TicketStatus {
  valid
  used
  expired
}

// ── Modèles ──────────────────────────────────────────────────────────────────

// Table propre à feetiPlay dans la DB feeti2 (évite conflit avec User de feeti2)
model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  passwordHash     String
  phone            String?
  avatar           String?
  role             UserRole         @default(viewer)
  subscriptionPlan SubscriptionPlan @default(free)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tickets         Ticket[]
  watchHistory    WatchHistory[]
  favorites      UserFavorite[]

  @@map("FeetiPlayUser")
}

// Table propre à feetiPlay dans la DB feeti2 (évite conflit avec les admins feeti2 via Role)
model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  avatar       String?
  role         AdminRole
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("FeetiPlayAdminUser")
}

model Channel {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  logo            String?
  coverImage      String?
  category        String
  isActive        Boolean  @default(true)
  subscriberCount Int      @default(0)
  eventCount      Int      @default(0)
  country         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events StreamingEvent[]
}

model StreamingEvent {
  id          String   @id @default(cuid())
  title       String
  description String
  date        String
  time        String
  duration    String
  image       String   @default("")
  channelId   String
  channelName String
  category    String
  tags        String   @default("[]") // JSON array
  isLive      Boolean  @default(false)
  isReplay    Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  isFree      Boolean  @default(true)
  price       Int?     // en FCFA
  currency    String   @default("FCFA")
  viewerCount Int      @default(0)
  streamUrl   String?
  muxStreamId String?  // ID du live stream Mux (pour le webhook)
  location    String?  // Lieu physique ou en ligne
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel    Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tickets   Ticket[]
  favorites UserFavorite[]
}

// Évite conflit avec la table Ticket de feeti2
model Ticket {
  id          String       @id @default(cuid())
  eventId     String
  userId      String
  holderName  String
  holderEmail String
  qrCode      String       @unique
  status      TicketStatus @default(valid)
  price       Int
  currency    String       @default("FCFA")
  purchaseDate DateTime    @default(now())
  streamUrl   String?

  event StreamingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("StreamingTicket")
}

// Évite conflit avec la table WatchHistory potentielle de feeti2
model WatchHistory {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  eventTitle String
  watchedAt  DateTime @default(now())
  progress   Int      @default(0) // 0-100 %
  duration   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("FeetiPlayWatchHistory")
}

model AdminNotification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info | warning | promo | maintenance
  audience  String   @default("all") // all | premium | free
  sentBy    String
  sentAt    DateTime @default(now())
  readCount Int      @default(0)

  @@index([sentAt(sort: Desc)])
  @@map("FeetiPlayAdminNotification")
}

model SystemLog {
  id          String   @id @default(cuid())
  action      String
  description String
  level       String   @default("info") // info | success | warning | error
  adminName   String
  adminRole   String
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([level])
  @@map("FeetiPlaySystemLog")
}

// Évite conflit avec la table UserFavorite de feeti2
model UserFavorite {
  id           String         @id @default(cuid())
  userId        String
  eventId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  streamingEvent StreamingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@unique([userId, eventId])
  @@map("StreamingFavorite")
}
